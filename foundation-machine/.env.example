# Copy this to .env and fill it in. .env is git-ignored — your keys never get committed.

# --- Anthropic (Claude) --- REQUIRED. Calls Claude to write the docs.
# Get one at https://console.anthropic.com/  ->  Settings  ->  API Keys  ->  Create Key
ANTHROPIC_API_KEY=

# --- Supabase --- only needed to read LIVE form submissions (--latest / --client).
# Leave blank to test offline with  ./run.sh --sample
# Get it: Supabase dashboard -> Project Settings -> API -> "service_role" secret key.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=https://hiqlubrygiprmelechza.supabase.co

# Optional: override the model (default is Opus 4.8, the best for these docs).
# FOUNDATION_MODEL=claude-opus-4-8
